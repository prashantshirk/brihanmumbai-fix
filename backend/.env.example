# Copy this file to .env and fill in your values
# Never commit .env to git

# ── App ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace-this-with-at-least-32-random-characters
ADMIN_JWT_SECRET=replace-this-with-at-least-32-random-characters-admin

# ── Database ─────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/brihanmumbai?retryWrites=true&w=majority

# ── AI Vision (Gemini - each model has separate RPD quota on same key) ─
GEMINI_API_KEY=AIza...

# ── AI Text ──────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Image Storage ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret